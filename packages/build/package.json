{
  "name": "@funish/build",
  "version": "0.1.4",
  "description": "Modern build system powered by tsdown (Rolldown + Oxc) with Jiti stub support",
  "keywords": [
    "build",
    "bundling",
    "cli",
    "development-toolkit",
    "jiti",
    "oxc",
    "rolldown",
    "stub",
    "tsdown",
    "typescript",
    "zero-config"
  ],
  "homepage": "https://github.com/funish/basis#readme",
  "bugs": {
    "url": "https://github.com/funish/basis/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Funish",
    "email": "official@funish.net",
    "url": "https://funish.net/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/funish/basis.git",
    "directory": "packages/build"
  },
  "bin": {
    "isbuild": "dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./config": {
      "types": "./dist/config.d.mts",
      "import": "./dist/config.mjs"
    },
    "./command": {
      "types": "./dist/command.d.mts",
      "import": "./dist/command.mjs"
    }
  },
  "scripts": {
    "dev": "jiti src/cli.ts --stub",
    "build": "jiti src/cli.ts",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "c12": "4.0.0-beta.4",
    "citty": "0.2.2",
    "consola": "3.4.2",
    "defu": "6.1.7",
    "jiti": "2.6.1",
    "knitwork": "1.3.0",
    "mlly": "1.8.2",
    "pathe": "2.0.3",
    "pkg-types": "2.3.0",
    "pretty-bytes": "7.1.0",
    "tinyglobby": "0.2.16",
    "tsdown": "0.21.9"
  }
}
