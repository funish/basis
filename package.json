  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/funish/basis.git"
  },
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "lint": "basis lint",
    "fmt": "basis fmt",
